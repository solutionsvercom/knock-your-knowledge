{
  "name": "kyk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "kill:api": "node scripts/kill-api-port.mjs",
    "dev": "npm run kill:api && concurrently -n api,web -c \"cyan,magenta\" \"npm run dev -w kyk-backend\" \"npm run dev -w kyk-frontend\"",
    "dev:client": "npm run dev -w kyk-frontend",
    "dev:server": "npm run dev -w kyk-backend",
    "build": "npm run build -w kyk-frontend",
    "build:client": "npm run build -w kyk-frontend",
    "start:client": "npm run start:client -w kyk-frontend",
    "start:server": "npm run start -w kyk-backend",
    "lint": "npm run lint -w kyk-frontend",
    "lint:fix": "npm run lint:fix -w kyk-frontend",
    "typecheck": "npm run typecheck -w kyk-frontend",
    "preview": "npm run preview -w kyk-frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
